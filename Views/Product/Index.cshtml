@model IEnumerable<WebGoiY.Models.Product>
@{
    // Hứng danh sách Categories từ ViewBag , vì ko thể dùng for với viewbag   
    var categories = ViewBag.Categories as List<WebGoiY.Models.Category> ?? new List<WebGoiY.Models.Category>();
}    
@if (TempData["OrderSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show text-center my-3" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["OrderSuccess"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="container mt-4">
    <div class="row">
        <!-- 1. BANNER CHÍNH -->
        <div class="col-12 mb-4">
            <div class="rounded overflow-hidden shadow-sm position-relative banner-hover">
                <img src="~/img/Banner.png" class="img-fluid w-100" alt="Main Banner">
            </div>
        </div>

        <!-- 2. KHỐI DANH MỤC DẠNG LƯỚI (GRID CATEGORIES) NGAY DƯỚI BANNER -->
        @if (categories.Any())
        {
            <div class="col-12 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
                    <h5 class="mb-0 fw-bold text-dark border-start border-brand border-4 ps-2">Explore Categories</h5>
                </div>

                <div class="row row-cols-3 row-cols-sm-4 row-cols-md-6 g-3 text-center">
                    @foreach (var cat in categories)
                    {
                        <div class="col">
                            <a href="/Product/ShowShopPage?page=1&categories=@cat.CategoryId" class="text-decoration-none group-cat d-block">
                                <div class="p-3 bg-white rounded shadow-sm border h-100 transition-all hover-up">
                                    <div class="mx-auto mb-2 overflow-hidden rounded-circle bg-light border d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                                        <img src="@(string.IsNullOrEmpty(cat.ImagePath) ? "https://placehold.co/300x300/e9ecef/495057?text=No+Image" : cat.ImagePath)" 
                                             class="w-100 h-100 object-fit-cover" alt="@cat.CategoryName">
                                    </div>
                                    <h6 class="text-dark small fw-bold mb-0 text-truncate" style="font-size: 13px;">@cat.CategoryName</h6>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- 3. DANH SÁCH SẢN PHẨM NỔI BẬT (TRENDING PRODUCTS) -->
        <div class="col-12 mb-3 pb-2 border-bottom d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-dark border-start border-brand border-4 ps-2">Trending Products</h5>
            <a href="/Product/ShowShopPage?page=1" class="text-decoration-none text-brand small fw-bold">
                See all <i class="fa-solid fa-chevron-right ms-1" style="font-size: 10px;"></i>
            </a>
        </div>

        <div class="row row-cols-2 row-cols-md-3 row-cols-xl-4 g-3">
            @if (Model != null && Model.Any())
            {
                @foreach (var p in Model)
                { 
                    <div class="col">
                        <a href="/Product/Detail?id=@p.ProductId" class="text-decoration-none h-100 d-block">
                            <div class="card h-100 shadow-sm border-0 product-card">
                                <div class="position-relative overflow-hidden bg-light" style="aspect-ratio: 1/1;">
                                    <img src="@(string.IsNullOrEmpty(p.ImagePath) ? "https://placehold.co/300x300/e9ecef/495057?text=No+Image" : p.ImagePath)" 
                                         class="card-img-top w-100 h-100 object-fit-cover" alt="Product Image">
                                </div>

                                <div class="card-body p-3 d-flex flex-column bg-white">
                                    <h6 class="card-title text-truncate mb-2 text-dark" style="font-size: 14px;">@p.ProductName</h6>
                                    <div class="mt-auto">
                                        <div class="d-flex align-items-baseline mb-1">
                                            <span class="text-brand fw-bold me-2">@p.Price.ToString("N2") £</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted py-4">
                    Không tìm thấy sản phẩm nổi bật nào.
                </div>
            }
        </div>
    </div>
</div>