@using Microsoft.AspNetCore.Http
@using WebGoiY.Helpers
@{
    ViewData["Title"] = "Secure Checkout";
    
    // Đọc thông tin User từ Session để tự động điền (Auto-fill) vào form
    var loggedInUser = Context.Session.GetObjectFromJson<WebGoiY.Models.User>("loggedInUser");
    
    // Hứng danh sách sản phẩm và phân rã dòng tiền từ CSDL mới nâng cấp
    var cartItems = ViewBag.CartItems as List<WebGoiY.Models.Cart>;
    
    decimal subtotalPrice = ViewBag.SubtotalPrice ?? 0m;
    decimal discountAmount = ViewBag.DiscountAmount ?? 0m;
    decimal taxAmount = ViewBag.TaxAmount ?? 0m;
    decimal shippingFee = ViewBag.ShippingFee ?? 0m;
    decimal totalPrice = ViewBag.TotalPrice ?? 0m;
}

 

<div class="container mt-4 mb-5">
    <div class="row">
        <!-- TIÊU ĐỀ TRANG CHÍNH -->
        <div class="col-12 mb-4">
            <h3 class="fw-bold text-dark d-flex align-items-center gap-2">
                <i class="fa-solid fa-shield-halved text-brand"></i> Secure Checkout
            </h3>
            <p class="text-muted small mb-0">Please review your order items and provide accurate shipping information.</p>
            <hr class="opacity-10 mt-3">
        </div>

        <!-- CỘT BÊN TRÁI: FORM NHẬP THÔNG TIN GIAO HÀNG & PHƯƠNG THỨC THANH TOÁN -->
        <div class="col-lg-7 mb-4">
            <div class="checkout-card p-4 border">
                <h5 class="fw-bold text-dark mb-4 border-bottom pb-2">
                    <i class="fa-solid fa-truck-fast me-2 text-muted"></i>Shipping & Billing Details
                </h5>

                <form action="/Checkout/PlaceOrder" method="post">
                    <!--  GỬI NGẦM DÒNG TIỀN XUỐNG DATABASE ĐỒNG BỘ -->
                    <input type="hidden" name="subtotalPrice" value="@subtotalPrice" />
                    <input type="hidden" name="discountAmount" value="@discountAmount" />
                    <input type="hidden" name="taxAmount" value="@taxAmount" />
                    <input type="hidden" name="shippingFee" value="@shippingFee" />
                    <input type="hidden" name="totalPrice" value="@totalPrice" />

                    <div class="row g-3">
                        <!-- Tên người nhận -->
                        <div class="col-12">
                            <label class="form-label small fw-bold text-secondary">Recipient's Full Name *</label>
                            <input type="text" name="recipientName" required class="form-control"
                                   value="@(loggedInUser != null ? loggedInUser.FullName : "")"
                                   placeholder="e.g. Vu Long">
                        </div>

                        <!-- Số điện thoại nhận hàng -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary">Phone Number *</label>
                            <input type="tel" name="phoneNumber" required class="form-control"
                                   value="@(loggedInUser != null ? loggedInUser.Phone : "")"
                                   placeholder="e.g. 0901234567">
                        </div>

                        <!-- Địa chỉ Email -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary">Email Address (Optional)</label>
                            <input type="email" name="email" class="form-control"
                                   value="@(loggedInUser != null ? loggedInUser.Email : "")"
                                   placeholder="name@example.com">
                        </div>

                        <!-- Địa chỉ nhận hàng -->
                        <div class="col-12">
                            <label class="form-label small fw-bold text-secondary">Full Delivery Address *</label>
                            <textarea name="shippingAddress" required class="form-control" rows="3"
                                      placeholder="Apartment number, street name, ward, district, city...">@(loggedInUser != null ? loggedInUser.Address : "")</textarea>
                        </div>

                        <!-- Ghi chú đơn hàng -->
                        <div class="col-12">
                            <label class="form-label small fw-bold text-secondary">Order Notes (Optional)</label>
                            <textarea name="orderNotes" class="form-control" rows="2" placeholder="Notes about your delivery, e.g. time preferences, gate codes..."></textarea>
                        </div>
                    </div>

                    <!-- KHỐI PHƯƠNG THỨC THANH TOÁN -->
                    <h5 class="fw-bold text-dark mt-4 pt-2 mb-3 border-bottom pb-2">
                        <i class="fa-solid fa-wallet me-2 text-muted"></i>Payment Method
                    </h5>
                    <div class="d-flex flex-column gap-2 mb-4">
                        <!-- Tùy chọn 1: COD -->
                        <div class="payment-method-box">
                            <div class="form-check m-0">
                                <input class="form-check-input" type="radio" name="paymentMethod" id="paymentCOD" value="COD" checked>
                                <label class="form-check-label fw-bold small text-dark" for="paymentCOD">
                                    <i class="fa-solid fa-money-bill-wave text-success me-2"></i> Cash on Delivery (COD)
                                </label>
                                <p class="text-muted small m-0 ps-4 mt-1">Pay safely with cash right at your doorstep upon receiving the package.</p>
                            </div>
                        </div>

                        <!-- Tùy chọn 2: BANK TRANSFER -->
                        <div class="payment-method-box">
                            <div class="form-check m-0">
                                <input class="form-check-input" type="radio" name="paymentMethod" id="paymentBank" value="BANK_TRANSFER">
                                <label class="form-check-label fw-bold small text-dark" for="paymentBank">
                                    <i class="fa-solid fa-building-columns text-primary me-2"></i> Direct Bank Transfer
                                </label>
                                <p class="text-muted small m-0 ps-4 mt-1">Transfer directly to our corporate bank account. We will process shipping right after confirmation.</p>
                            </div>
                        </div>

                        <!-- Tùy chọn 3: VNPAY -->
                        <div class="payment-method-box">
                            <div class="form-check m-0">
                                <input class="form-check-input" type="radio" name="paymentMethod" id="paymentVNPAY" value="VNPAY">
                                <label class="form-check-label fw-bold small text-dark" for="paymentVNPAY">
                                    <i class="fa-solid fa-qrcode text-danger me-2"></i> VNPay Gateway (E-Wallet / QR Code)
                                </label>
                                <p class="text-muted small m-0 ps-4 mt-1">Pay instantly and securely via VNPay secure gateway using any local Banking Apps.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Nút chốt đơn -->
                    <button type="submit" class="btn btn-brand btn-lg w-100 py-3 fw-bold small mt-2 shadow-sm" style="font-size: 14px; letter-spacing: 1px; border-radius: 8px;">
                        CONFIRM & PLACE ORDER <i class="fa-solid fa-circle-check ms-2"></i>
                    </button>
                </form>
            </div>
        </div>

        <!-- CỘT BÊN PHẢI: TÓM TẮT ĐƠN HÀNG -->
        <div class="col-lg-5">
            <div class="checkout-card p-4 border position-sticky" style="top: 20px;">
                <h5 class="fw-bold text-dark mb-4 border-bottom pb-2">Your Order Summary</h5>

                <!-- Danh sách sản phẩm thu nhỏ -->
                <div class="product-scroll-area mb-4">
                    @if (cartItems != null)
                    {
                        foreach (var item in cartItems)
                        {
                            <div class="d-flex align-items-center justify-content-between py-2 border-bottom border-light">
                                <div class="d-flex align-items-center gap-3 text-truncate" style="max-width: 75%;">
                                    <img src="@(item.Product != null && !string.IsNullOrEmpty(item.Product.ImagePath) ? item.Product.ImagePath : "/images/default_product.png")"
                                         class="rounded bg-light border object-fit-cover" style="width: 52px; height: 52px;" alt="Item Image">
                                    <div class="text-truncate">
                                        <h6 class="text-dark fw-bold small text-truncate mb-0">@(item.Product != null ? item.Product.ProductName : "Product Item")</h6>
                                        <span class="text-muted small">Qty: @item.Quantity</span>
                                    </div>
                                </div>
                              
                                <span class="fw-bold small text-secondary">@(((decimal)item.Amount).ToString("N2")) £</span>
                            </div>
                        }
                    }
                </div>

                <!-- BẢNG TÍNH TOÁN DÒNG TIỀN CHI TIẾT -->
                <div class="d-flex justify-content-between mb-2 small text-secondary">
                    <span>Subtotal</span>
                    <span class="fw-medium">@subtotalPrice.ToString("N2") £</span>
                </div>
                <div class="d-flex justify-content-between mb-2 small text-secondary">
                    <span>Discount</span>
                    <span class="text-danger">-@discountAmount.ToString("N2") £</span>
                </div>
                <div class="d-flex justify-content-between mb-2 small text-secondary">
                    <span>Tax (VAT 10%)</span>
                    <span class="text-dark">+@taxAmount.ToString("N2") £</span>
                </div>
                <div class="d-flex justify-content-between mb-3 small text-secondary">
                    <span>Shipping </span>   
                    <span class="@(shippingFee == 0 ? "text-success fw-bold" : "text-dark")">
                        @(shippingFee == 0 ? "FREE" : shippingFee.ToString("N2") + " £")
                    </span>
                </div>
                <hr class="opacity-10">
                <<div class="d-flex justify-content-between align-items-baseline pt-2">
                    <span class="fw-bold text-dark fs-6">Total Due</span>
                    <h3 class="text-brand fw-bold mb-0">@totalPrice.ToString("N2") £</h3>
                </div>
            </div>
        </div>
    </div>
</div>