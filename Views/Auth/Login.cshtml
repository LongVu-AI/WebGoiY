<div class="container my-5 py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="bg-white p-5 rounded shadow-sm border">
                <!-- Tiêu đề Form -->
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-dark">ACCOUNT LOGIN</h3>
                    <p class="text-muted small">Welcome back to Zay Shop</p>
                </div>

                <!-- KHỐI HIỂN THỊ THÔNG BÁO LỖI (Đã sửa: ViewBag.Error) -->
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2 small border-0 rounded mb-3 text-center" role="alert">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i> <span>@ViewBag.Error</span>
                    </div>
                }
                
                <!-- KHỐI HIỂN THỊ THÔNG BÁO ĐĂNG KÝ THÀNH CÔNG -->
                @if (Context.Request.Query["success"] == "true")
                {
                    <div class="alert alert-success py-2 small border-0 rounded mb-3 text-center" role="alert">
                        <i class="fa-solid fa-circle-check me-2"></i> Registration successful! Please log in.
                    </div>
                }

                <!-- Form gửi dữ liệu Đăng Nhập -->
                <form action="/Auth/HandleLogin" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Username *</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="fa-solid fa-user small"></i></span>
                            <!-- Đã sửa: name="userName" -->
                            <input type="text" name="userName" required class="form-control border-start-0 ps-0" placeholder="Enter your username">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary">Password *</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="fa-solid fa-lock small"></i></span>
                            <!-- Đã sửa: name="passWord" -->
                            <input type="password" name="passWord" required class="form-control border-start-0 ps-0" placeholder="Enter your password">
                        </div>
                    </div>

                    <!-- Nút Đăng Nhập -->
                    <button type="submit" class="btn btn-brand btn-lg w-100 py-2.5 fw-bold small mb-3" style="font-size: 14px; letter-spacing: 0.5px;">
                        LOG IN <i class="fa-solid fa-arrow-right-to-bracket ms-2"></i>
                    </button>

                    <!-- Link chuyển sang Đăng Ký -->
                    <div class="text-center mt-3 small">
                        <span class="text-muted">New to Zay Shop?</span>
                        <a href="/Auth/Register" class="text-brand text-decoration-none fw-bold ms-1 hover-brand">Create an account</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>